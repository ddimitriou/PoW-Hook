# All PoW-Hook configuration is set via the POW environment variable as a JSON object.
# Copy this file to .env (which is gitignored) and customise the values below.
#
# Available keys:
#   checks_cmd       - Command to execute for custom validation checks (e.g., trufflehog)
#   admin_handles    - GitHub handles to notify in PR comments (e.g., "@ddimitriou @security")
#   github_pat_local - GitHub PAT with 'actions' scope for server-side attestation dispatch
#   github_repo      - owner/repo slug for attestation dispatch (e.g., "ddimitriou/pow-hook")
#   ssh_key          - Path to SSH private key (auto-detected by setup_hooks.py)
#   ssh_key_override - Override SSH key path for testing/CI
#   github_token     - GitHub token for pre-receive hook (Enterprise)
#   github_api_url   - Custom GitHub API URL for Enterprise Server
#   enforce          - Set to "true" to enable server-side enforcement
#
POW='{"checks_cmd":"docker run --rm -v \"$(git rev-parse --show-toplevel)\":/pwd trufflesecurity/trufflehog:latest filesystem /pwd --no-verification --fail","admin_handles":"@sfitsos"}'
