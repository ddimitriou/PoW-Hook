#!/usr/bin/env python3
import sys
import os
import subprocess
import base64
import json
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.primitives.asymmetric import padding
from cryptography.hazmat.primitives.asymmetric.rsa import RSAPrivateKey
from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
from cryptography.hazmat.primitives.asymmetric.ed448 import Ed448PrivateKey
from cryptography.hazmat.primitives.asymmetric.ec import EllipticCurvePrivateKey, ECDSA

msg_file = sys.argv[1]
passed_flag = ".git/POW_PASSED"


def load_env():
    try:
        repo_root = subprocess.check_output(["git", "rev-parse", "--show-toplevel"]).decode().strip()
        env_path = os.path.join(repo_root, ".env")
        if os.path.exists(env_path):
            with open(env_path) as f:
                for line in f:
                    if "=" in line and not line.strip().startswith("#"):
                        key, val = line.strip().split("=", 1)
                        val = val.strip().strip("'\"")
                        if key not in os.environ:
                            os.environ[key] = val
    except Exception:
        pass


def find_ssh_key():
    """Return the SSH private key path used for github.com connections."""
    # Priority 1: Specifically configured key from setup
    env_key = os.environ.get("POW_SSH_KEY")
    if env_key and os.path.exists(env_key):
        return env_key

    # Priority 2: Test/CI override
    override = os.environ.get("POW_SSH_KEY_OVERRIDE")
    if override and os.path.exists(override):
        return override

    # Priority 3: Resolve via ssh -G
    try:
        out = subprocess.check_output(
            ["ssh", "-G", "github.com"], stderr=subprocess.DEVNULL
        ).decode()
        for line in out.splitlines():
            if line.startswith("identityfile "):
                path = os.path.expanduser(line.split(None, 1)[1])
                if os.path.exists(path):
                    return path
    except Exception:
        pass

    # Priority 4: Default candidates
    for candidate in ["~/.ssh/id_rsa", "~/.ssh/id_ed25519", "~/.ssh/id_ecdsa"]:
        path = os.path.expanduser(candidate)
        if os.path.exists(path):
            return path
    return None


def load_private_key(key_path):
    """Load a private key from file, handling both OpenSSH and legacy PEM formats."""
    with open(key_path, "rb") as f:
        key_data = f.read()
    if b"OPENSSH PRIVATE KEY" in key_data:
        return serialization.load_ssh_private_key(key_data, password=None)
    return serialization.load_pem_private_key(key_data, password=None)


def sign_with_key(private_key, payload_bytes):
    """Sign payload_bytes with the given private key."""
    if isinstance(private_key, RSAPrivateKey):
        return private_key.sign(payload_bytes, padding.PKCS1v15(), hashes.SHA256())
    elif isinstance(private_key, (Ed25519PrivateKey, Ed448PrivateKey)):
        return private_key.sign(payload_bytes)
    elif isinstance(private_key, EllipticCurvePrivateKey):
        return private_key.sign(payload_bytes, ECDSA(hashes.SHA256()))
    raise ValueError(f"Unsupported key type: {type(private_key).__name__}")


load_env()

if os.path.exists(passed_flag):
    with open(passed_flag, "r") as f:
        session_data = json.load(f)
    os.remove(passed_flag)

    session_id = session_data["session_id"]
    status = session_data["status"]
    pow_checks_hash = session_data.get("pow_checks_hash", "")

    try:
        tree_hash = subprocess.check_output(["git", "write-tree"]).decode().strip()
        sign_payload = f"{pow_checks_hash}|{tree_hash}|{session_id}|{status}"

        key_path = find_ssh_key()
        if not key_path:
            print("❌ Error: No SSH private key found. Run setup_hooks.py again.")
            sys.exit(1)
        private_key = load_private_key(key_path)

        signature = sign_with_key(private_key, sign_payload.encode())
        token = base64.b64encode(signature).decode()
        
        bundle = json.dumps({
            "token": token,
            "session": session_id,
            "status": status,
            "checks_hash": pow_checks_hash
        })
        pow_checks = base64.b64encode(bundle.encode()).decode()

        # Strip comment lines (e.g., from MERGE_MSG) before injecting trailers.
        # Without this, git interpret-trailers appends trailers after comments;
        # git then strips the comments and the blank line separator is lost,
        # so %(trailers:...) can no longer find the trailer block.
        cleaned = subprocess.check_output(
            ["git", "stripspace", "--strip-comments"],
            stdin=open(msg_file, "rb"),
        )
        with open(msg_file, "wb") as f:
            f.write(cleaned)

        subprocess.check_call([
            "git", "interpret-trailers", "--in-place",
            "--trailer", f"PoW-Checks: {pow_checks}",
            msg_file
        ])
    except Exception as e:
        print(f"❌ Error: Failed to sign tree or inject trailer: {e}")
        sys.exit(1)
else:
    print("⚠️ Warning: No Proof-of-Work checks executed. Push will be rejected by backend.")
